{
  "name": "exam-module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "next lint",
    "codegen": "graphql-codegen --config codegen.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply exam-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply exam-db --remote",
    "pages:build": "npx @cloudflare/next-on-pages",
    "deploy": "npm run codegen && npm run pages:build && node scripts/deploy-pages.mjs",
    "ship": "npm run db:migrate:remote && npm run deploy"
  },
  "dependencies": {
    "@apollo/client": "^3.12.0",
    "@graphql-tools/merge": "^9.1.7",
    "@graphql-tools/schema": "^10.0.31",
    "@livekit/components-react": "^2.9.20",
    "@mediapipe/face_detection": "^0.4.1646425229",
    "@tensorflow-models/face-detection": "^1.0.3",
    "@tensorflow/tfjs": "^4.22.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "drizzle-orm": "^0.45.1",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "graphql-yoga": "^5.18.1",
    "jose": "^6.0.12",
    "livekit-client": "^2.18.0",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^1.6.0",
    "md5": "^2.3.0",
    "next": "15.2.0",
    "pusher-js": "^8.4.3",
    "radix-ui": "^1.4.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-codegen/typescript-react-apollo": "^4.4.1",
    "@graphql-codegen/typescript-resolvers": "^5.1.7",
    "@parcel/watcher": "^2.5.6",
    "@tailwindcss/postcss": "^4",
    "@types/md5": "^2.3.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.76.0"
  }
}
